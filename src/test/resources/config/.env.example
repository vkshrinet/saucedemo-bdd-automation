# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# These environment variables override config/{env}.properties values.

# Application
BASE_URL=https://www.saucedemo.com

# Browser
BROWSER=chrome
HEADLESS=false
ENV=qa

# Database credentials (inject via CI/CD secrets manager, not this file)
DB_URL=jdbc:mysql://localhost:3306/saucedemo_db
DB_USERNAME=qa_user
DB_PASSWORD=your_password_here
